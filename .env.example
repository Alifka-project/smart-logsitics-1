# SAP integration environment variables
SAP_BASE_URL=https://my-sap-host.example.com
SAP_USERNAME=your_sap_username
SAP_PASSWORD=your_sap_password

# Server
PORT=4000

# D7 Networks — SMS and WhatsApp
# SMS: D7_ORIGINATOR (e.g. SignOTP for UAE OTP route)
# WhatsApp: uses https://api.d7networks.com/whatsapp/v2/send (NOT the SMS endpoint)
D7_API_TOKEN=
D7_ORIGINATOR=SignOTP
# WhatsApp Business number as registered in D7 (digits only, e.g. 971588712409)
D7_WHATSAPP_NUMBER=
# Optional alias; digits are extracted if you use +971...
# D7_WHATSAPP_ORIGINATOR=
# Optional: separate JWT for WhatsApp if D7 gave a different token than SMS
# D7_WHATSAPP_TOKEN=
# WHATSAPP_PROVIDER=d7

# --- D7 WhatsApp Meta template (first contact / confirmation) ---
# After Meta approves your template in D7, set the exact template NAME from the dashboard.
# Body in D7: "Dear {{1}}, your order {{2}} ... following {{3}} ... contact {{4}}."
#   {{1}} = customer name   {{2}} = order ref (#PO...)   {{3}} = confirmation URL   {{4}} = +971524408687
# D7_WHATSAPP_CONFIRMATION_TEMPLATE=
# Use the language code Meta shows (often en or en_US)
# D7_WHATSAPP_TEMPLATE_LANGUAGE=en
