# SAP integration environment variables
SAP_BASE_URL=https://my-sap-host.example.com
SAP_USERNAME=your_sap_username
SAP_PASSWORD=your_sap_password

# Server
PORT=4000

# D7 Networks — SMS and WhatsApp (same API token)
# SMS: D7_ORIGINATOR is used (e.g. SignOTP for UAE OTP route)
# WhatsApp: set D7_WHATSAPP_ORIGINATOR to your D7-approved WhatsApp Business number (E.164)
D7_API_TOKEN=
D7_ORIGINATOR=SignOTP
D7_WHATSAPP_ORIGINATOR=
# Optional: force provider (default: d7 when D7_API_TOKEN + D7_WHATSAPP_ORIGINATOR are set)
# WHATSAPP_PROVIDER=d7
